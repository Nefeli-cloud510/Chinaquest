<svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <!-- 黑白版本用于 Hiro 识别 -->
  <rect width="512" height="512" fill="#FFFFFF"/>
  
  <!-- 黑色边框 -->
  <rect x="20" y="20" width="472" height="472" fill="none" stroke="#000000" stroke-width="8"/>
  
  <!-- 四角定位块 -->
  <g fill="#000000">
    <rect x="40" y="40" width="100" height="100"/>
    <rect x="372" y="40" width="100" height="100"/>
    <rect x="40" y="372" width="100" height="100"/>
    <rect x="372" y="372" width="100" height="100"/>
  </g>
  
  <!-- 中心编码图案 -->
  <g transform="translate(256, 256)" fill="#000000">
    <rect x="-80" y="-80" width="160" height="160"/>
    <rect x="-60" y="-60" width="120" height="120" fill="#FFFFFF"/>
    <rect x="-40" y="-40" width="80" height="80"/>
    <rect x="-20" y="-20" width="40" height="40" fill="#FFFFFF"/>
  </g>
</svg>
